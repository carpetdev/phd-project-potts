{
  "terminal.integrated.commandsToSkipShell": ["-language-julia.interrupt"],
  "[julia]": {
    "editor.quickSuggestions": {
      "strings": "off",
      "comments": "off",
      "other": "off"
    },
    "editor.defaultFormatter": "aviatesk.jetls-client"
  },
  "julia.lint.iter": false,
  "julia.lint.call": false,
  "julia.NumThreads": "auto",
  "julia.additionalArgs": ["--project=Potts"],
  "jetls-client.settings": {
    "inlay_hint": { "types": { "enabled": false } }
  }
}
